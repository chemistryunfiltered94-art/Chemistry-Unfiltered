rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Safe admin check — returns false (not error) when unauthenticated.
    // This matters for Server Component reads where request.auth is null.
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Users ──────────────────────────────────────────────────
    // Deliberately locked to owner/admin only, including list/count —
    // a public student count is not worth exposing user collection
    // access to unauthenticated/non-admin clients. The public "সক্রিয়
    // শিক্ষার্থী" stat must be computed server-side (Admin SDK, which
    // bypasses these rules) and exposed via a small API route instead
    // of a direct client-side Firestore read.
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Topics ─────────────────────────────────────────────────
    // Published topics are world-readable (supports unauthenticated
    // server-side rendering). Admins can read all (including drafts).
    match /topics/{topicId} {
      allow read:  if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Articles ───────────────────────────────────────────────
    match /articles/{articleId} {
      allow read:  if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Formulas ───────────────────────────────────────────────
    match /formulas/{formulaId} {
      allow read:  if true;   // public, no auth required
      allow write: if isAdmin();
    }

    // ─── Reactions ──────────────────────────────────────────────
    match /reactions/{reactionId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Questions ──────────────────────────────────────────────
    match /questions/{questionId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Elements (Periodic Table static data) ──────────────────
    match /elements/{elementId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Settings (site-wide config) ────────────────────────────
    match /settings/{settingId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Virtual Labs ───────────────────────────────────────────
    match /virtual_labs/{labId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Progress ───────────────────────────────────────────────
    match /progress/{progressId} {
      allow read:   if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
    }

    // ─── Bookmarks ──────────────────────────────────────────────
    match /bookmarks/{bookmarkId} {
      allow read:   if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ─── Notes (private, per-user scratch notes) ─────────────────
    match /notes/{noteId} {
      allow read:   if isAdmin() ||
                       (isAuthenticated() &&
                        resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                               resource.data.userId == request.auth.uid;
    }

    // ─── Study Notes (public Notes Center: Class / Revision / ────
    // Practical notes ও ফর্মুলা শিট — admin-authored, shown on /notes).
    // Distinct from /notes above, which is private per-user content.
    // IMPORTANT: list queries from Next.js Server Components (SSG/SSR)
    // run without auth, so resource.data checks block them. All studyNotes
    // are admin-authored public content — fully open read is correct here.
    match /studyNotes/{noteId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Chapters ───────────────────────────────────────────────
    match /chapters/{chapterId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Revision Questions (উচ্চ মাধ্যমিক/অনার্স — Subject → Year → Q&A) ──
    // Published প্রশ্ন সবার জন্য readable (SSR support-এর জন্য), draft শুধু admin দেখতে পারবে।
    match /revisionQuestions/{questionId} {
      allow read:  if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Quiz Attempts ──────────────────────────────────────────
    match /quiz_attempts/{attemptId} {
      allow read:   if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Notifications ──────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
      allow write:  if isAdmin();
    }
  }
}
